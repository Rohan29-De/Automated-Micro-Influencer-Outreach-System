# Groq API key (required for AI message generation)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# SendGrid API key (optional - for production email sending)
# Get your key at: https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_key_here

# Instagram/Meta Access Token (optional - for production DM sending)
# Get via Meta Developer App: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here